TUSHARE_TOKEN=your_token_here
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/index_atlas
# WORKER_REQUIRE_DATA_CHECK=0
# 默认：仅当库内缺成分/股本/行情/申万等时才灌库（不重复请求）。若需每次启动都全量刷新：
# WORKER_STARTUP_FULL_PREPARE=1
# 关闭按需灌库（且未设上一项）：启动不打 Tushare
# WORKER_AUTO_BOOTSTRAP=0
# rt_k(doc 372) 相邻两轮开始的目标间隔（秒），默认 10；一轮含请求+写库，不足部分再 sleep；0=关闭
# RT_K_INTERVAL_SEC=0
# index_member_all(doc 335) 低档常为 1 次/分钟；默认 65，积分高可酌减
# INDEX_MEMBER_ALL_MIN_INTERVAL_SEC=65
# 申万：index_classify 来源，默认 SW2021
# SHENWAN_CLASSIFY_SRC=SW2021
# 按一级行业拉成分 L1（默认，请求少）；若接口返回空可试 L3
# SHENWAN_MEMBER_QUERY_LEVEL=L1
# 申万按分类拉 index_member_all 时，分类之间的间隔（秒）。高积分可 0.2～0.3（约 200～300 次/分）；低档遇限流可调大
# SHENWAN_MEMBER_INTERVAL_SEC=0.3
# daily(doc 27) → quotes_daily：保留的交易日种类数；初始化回填交易日数量
# QUOTES_DAILY_RETENTION_TRADE_DAYS=30
# QUOTES_DAILY_BOOTSTRAP_TRADE_DAYS=30
# 0=仅指数成分并集；1=全市场（默认，与接口单次按 trade_date 一致）
# QUOTES_DAILY_FULL_MARKET=0
