# 复制为项目根目录 `.env` 后填写（真实 `.env` 勿提交）。
# Worker / API 均从仓库根目录读取该文件；子目录内勿再维护一份完整清单。
# Docker 全栈 `docker compose up`：`api` / `worker` 使用 `env_file: .env`，
# 但 compose 里仍会覆盖 `DATABASE_URL` 等为 `...@db:5432`，容器内无需改连接串。

# -----------------------------------------------------------------------------
# 共用（API + Worker）
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/index_atlas

# -----------------------------------------------------------------------------
# Tushare（Worker 必填）
# -----------------------------------------------------------------------------
TUSHARE_TOKEN=

# -----------------------------------------------------------------------------
# API（Node BFF）
# -----------------------------------------------------------------------------
PORT=3001
BFF_CACHE_TTL_MS=4000
# 开发/单测：跳过库内数据就绪检查（勿用于生产）
# BFF_SKIP_DATA_CHECK=1

# -----------------------------------------------------------------------------
# Worker — 启动与灌库行为
# -----------------------------------------------------------------------------
# 启动时按快照检查，仅在有缺失时自动灌库；关则不在启动阶段请求 Tushare（须事先手动灌库）
# WORKER_AUTO_BOOTSTRAP=1
# 每次启动都全量灌库（强制请求 Tushare）；默认关
# WORKER_STARTUP_FULL_PREPARE=0
# 空库/灌库失败仍要起进程（仅调试，勿用于生产）
# WORKER_ALLOW_EMPTY_DB=0

# -----------------------------------------------------------------------------
# Worker — rt_k
# -----------------------------------------------------------------------------
# rt_k：相邻两轮「开始」的目标间隔（秒），默认 10；0=关闭
# RT_K_INTERVAL_SEC=10

# -----------------------------------------------------------------------------
# Worker — 申万行业同步
# -----------------------------------------------------------------------------
# index_classify 来源，默认 SW2021
# SHENWAN_CLASSIFY_SRC=SW2021
# 成分查询层级：L1（默认）；若返回空可试 L3
# SHENWAN_MEMBER_QUERY_LEVEL=L1
# 按分类拉 index_member_all 时，分类之间的间隔（秒）
# SHENWAN_MEMBER_INTERVAL_SEC=0.3

# -----------------------------------------------------------------------------
# Worker — quotes_daily（日线保留与灌库范围）
# -----------------------------------------------------------------------------
# 表中保留的 distinct 交易日数量上限（超出删更旧日期）
# QUOTES_DAILY_RETENTION_TRADE_DAYS=30
# 初始化灌库时回填的交易日数量
# QUOTES_DAILY_BOOTSTRAP_TRADE_DAYS=30
# 0=仅指数最新成分并集；1=全市场单日（默认）
# QUOTES_DAILY_FULL_MARKET=1
